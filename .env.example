PORT=4000
CORS_ORIGIN=http://localhost:8080
DATA_DIR=/app/sample_data
PROMPTS_DIR=/app/prompts
CACHE_FILE=/app/data/cache.json

# Leave blank for local defaults or point to the CAIO/OpenAI-compatible endpoint.
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=opusplan
TRANSCRIPTS_DB_ENABLED=true
DB_HOST=localhost
DB_PORT=5432
DB_USER=artemis
DB_PASS=artemis
DB_NAME=artemis_transcripts
TRANSCRIPT_CSV_DIR=/app/TB-Artemis-Summaries
SOURCE_FILES_DIR=/app/source_files
PIPELINE_INTERVAL_HOURS=6
PIPELINE_AUTO_RUN=true
