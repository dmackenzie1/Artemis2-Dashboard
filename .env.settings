# Non-secret environment settings for CAIO/OpenAI-compatible gateway usage.
# Copy these values into your local `.env` and set ANTHROPIC_API_KEY separately.

PORT=4000
CORS_ORIGIN=http://localhost:8080
DATA_DIR=/app/sample_data
PROMPTS_DIR=/app/prompts
CACHE_FILE=/app/data/cache.json

# CAIO production gateway (OpenAI-compatible endpoint)
ANTHROPIC_BASE_URL=https://llm-api-access.caio.mcp.nasa.gov/v1/chat/completions
ANTHROPIC_MODEL=gemini-3.1-pro-preview

TRANSCRIPTS_DB_ENABLED=false
DB_HOST=localhost
DB_PORT=5432
DB_USER=artemis
DB_PASS=artemis
DB_NAME=artemis_transcripts
TRANSCRIPT_CSV_DIR=/app/TB-Artemis-Summaries
SOURCE_FILES_DIR=/app/source_files
PIPELINE_INTERVAL_HOURS=6
PIPELINE_AUTO_RUN=true
