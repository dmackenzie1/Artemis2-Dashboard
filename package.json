{
  "name": "artemis2-dashboard",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "docker/client",
    "docker/server"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "lint": "npm run lint -w backend && npm run lint -w client",
    "test": "npm run test -w backend && npm run test -w client",
    "build": "npm run build -w backend && npm run build -w client",
    "dev:server": "npm run dev -w backend",
    "dev:client": "npm run dev -w client",
    "screenshot": "node scripts/capture-screenshot.js",
    "screenshot:client": "node scripts/capture-screenshot.js --url http://localhost:8080 --output artifacts/client-screenshot.png"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
