{
  "name": "backend",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && npm run copy:config",
    "copy:config": "mkdir -p dist/config && cp src/config/asr-corrections.json dist/config/asr-corrections.json",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run src",
    "db:ingest": "tsx src/scripts/ingest-transcripts.ts"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.6.12",
    "@mikro-orm/postgresql": "^6.6.12",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "lodash": "^4.18.1",
    "redis": "^5.11.0",
    "stopword": "^3.1.5",
    "wink-tokenizer": "^5.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
